{
    "_comment": "MCP server configurations for easy-claw. Copy to mcp_servers.json and edit.",
    "basic-memory": {
        "command": "uvx",
        "args": ["basic-memory", "mcp"]
    },
    "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
        "transport": "stdio"
    }
}
