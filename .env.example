# easy-claw 本地配置模板
#
# 使用方法：
#   1. 复制本文件为 `.env`
#   2. 按你的机器和模型服务修改配置
#
# 真实系统环境变量的优先级高于 `.env` 中的值。

# 模型名称，例如 deepseek-v4-pro、moonshot-v1-128k、glm-4-flash。
EASY_CLAW_MODEL=deepseek-v4-pro

# 兼容 OpenAI API 的模型服务地址。
# 如果不填写，默认使用 https://api.deepseek.com。
EASY_CLAW_BASE_URL=https://api.deepseek.com

# 模型服务密钥。
# 为兼容旧配置，如果这里为空，会继续读取 DEEPSEEK_API_KEY。
EASY_CLAW_API_KEY=

# 可选：覆盖本地运行数据目录。
# EASY_CLAW_DATA_DIR=D:\Pathon\Programs\easy-claw\data
EASY_CLAW_DATA_DIR=

# 可选：设置 Agent 默认操作的工作区。
# EASY_CLAW_WORKSPACE=D:\Pathon\Programs\easy-claw
EASY_CLAW_WORKSPACE=

# 工具调用审批模式。
# permissive = 优先可用性；本地命令、Python 和文件写入默认不暂停确认。
# balanced/strict = 对命令执行和文件写入启用人工确认。
EASY_CLAW_APPROVAL_MODE=permissive

# 执行模式。
# local = 当前 Windows 本机执行。
# 未来可以扩展为沙箱执行。
EASY_CLAW_EXECUTION_MODE=local

# 每轮对话的 LangChain 调用次数限制。
# 设置为 0 表示关闭对应限制。
EASY_CLAW_MAX_MODEL_CALLS=40
EASY_CLAW_MAX_TOOL_CALLS=100

# 搜索后端：
# auto = 有 Tavily 密钥时使用 Tavily，否则使用 DDGS
# ddgs = 强制使用 DDGS
# tavily = 强制使用 Tavily
EASY_CLAW_SEARCH_BACKEND=auto

# Tavily 搜索密钥。只有使用 Tavily 时才需要。
TAVILY_API_KEY=

# 可选：GitHub MCP 密钥。只在需要 GitHub 仓库、Issue、PR 等工具时填写。
# 建议使用权限最小的 GitHub 个人访问令牌。
GITHUB_PERSONAL_ACCESS_TOKEN=

# 可选：高德地图 MCP 密钥。只在需要地点搜索、路径规划等地图工具时填写。
AMAP_MAPS_API_KEY=

# 可选：把 Playwright 浏览器工具暴露给 Agent。
# 首次启用前请运行：uv run playwright install chromium
EASY_CLAW_BROWSER_ENABLED=false
EASY_CLAW_BROWSER_HEADLESS=false

# 可选：启用 MCP 工具。
# 可选值：
#   auto  = 存在 mcp_servers.json 时自动加载，服务失败时警告并继续启动（默认）
#   false = 完全关闭
#   true  = 强制启用；配置缺失或服务失败时直接报错
#
# 推荐用项目脚本一键配置默认 MCP：
#   .\scripts\start.ps1 -Mcp
#
# 该脚本会配置 basic-memory 和 Git；如果上面的 GitHub / 高德密钥已填写，也会启用对应 MCP。
EASY_CLAW_MCP_ENABLED=auto
EASY_CLAW_MCP_CONFIG=mcp_servers.json
