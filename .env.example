# easy-claw local configuration
#
# Copy this file to `.env` and edit the values for your machine.
# Values in the real process environment override values in `.env`.

# DeepSeek model name.
EASY_CLAW_MODEL=deepseek-v4-pro

# Required for DeepSeek API access.
DEEPSEEK_API_KEY=

# Optional: override local runtime data directory.
# EASY_CLAW_DATA_DIR=D:\Pathon\Programs\easy-claw\data
EASY_CLAW_DATA_DIR=

# Optional: default workspace the agent should treat as the active project.
# EASY_CLAW_WORKSPACE=D:\Pathon\Programs\easy-claw
EASY_CLAW_WORKSPACE=
